# Zerodha Kite credentials
KITE_API_KEY=your_api_key_here
KITE_API_SECRET=your_api_secret_here
KITE_ACCESS_TOKEN=           # filled at runtime by auth flow, or paste manually

# Trading mode: PAPER or LIVE
TRADE_MODE=PAPER

# Risk settings
MAX_CONCURRENT_SCALPS=2
DAILY_LOSS_LIMIT=3000
OI_THRESHOLD=500000          # 5 lakh contracts

# Instrument
UNDERLYING=NIFTY
EXCHANGE=NFO    
LOT_SIZE=10
